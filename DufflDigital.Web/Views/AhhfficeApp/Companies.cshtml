@model IEnumerable<DufflDigital.Web.Models.Company>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Duffl | Company Management</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body { background-color: #f8f9fa; }

        .sidebar {
            min-height: 100vh;
            width: 250px;
            background-color: #212529;
            color: white;
            position: fixed;
            z-index: 100;
        }

        .main-content { margin-left: 250px; padding: 20px; }

        .nav-link { color: rgba(255,255,255,0.7); transition: 0.3s; }
        .nav-link:hover { color: #FFB300; }
        .nav-link.active { color: #FFB300; font-weight: bold; }

        thead th {
            background: #212529;
            color: #fff;
            font-size: 13px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            padding: 14px 16px;
            border: none;
        }

        tbody td {
            padding: 12px 16px;
            vertical-align: middle;
            font-size: 14px;
            border-bottom: 1px solid #f0f0f0;
        }

        tbody tr:hover { background-color: #fffbf0; }
    </style>
</head>
<body>

    <!-- Sidebar -->
    <div class="sidebar d-flex flex-column p-3">
        <h3 class="text-center mb-4">Duffl <span class="fw-light">Admin</span></h3>
        <ul class="nav nav-pills flex-column mb-auto">
            <li class="nav-item">
                <a asp-controller="Dashboard" asp-action="Index" class="nav-link">
                    <i class="bi bi-speedometer2 me-2"></i> Dashboard
                </a>
            </li>
            <li>
                <a asp-controller="AhhfficeApp" asp-action="Index"
                   class="nav-link active">
                    <i class="bi bi-buildings me-2"></i> Ahhffice App
                </a>
            </li>
            <li>
                <a href="#" class="nav-link">
                    <i class="bi bi-gear me-2"></i> Settings
                </a>
            </li>
        </ul>
        <hr>
        <a asp-controller="Account" asp-action="Logout"
           class="btn btn-outline-danger btn-sm w-100">
            <i class="bi bi-box-arrow-right me-2"></i> Logout
        </a>
    </div>

    <!-- Main Content -->
    <div class="main-content">

        <!-- Top Bar -->
        <nav class="navbar navbar-expand-lg mb-4 rounded px-3 bg-white shadow-sm">
            <div class="container-fluid">
                <span class="navbar-brand mb-0 h5 text-secondary fw-bold">
                    <i class="bi bi-buildings me-2 text-warning"></i>
                    Company Infrastructure
                </span>
                <div class="d-flex gap-2">
                    <!-- Back goes to Ahhffice module landing, not Dashboard -->
                    <a asp-controller="AhhfficeApp" asp-action="Index"
                       class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-arrow-left me-1"></i> Back
                    </a>
                    <a asp-action="Manage"
                       class="btn btn-warning text-white fw-bold btn-sm px-3">
                        <i class="bi bi-plus-lg me-1"></i> Add Company
                    </a>
                </div>
            </div>
        </nav>

        <!-- Table -->
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Logo</th>
                        <th>Company Name</th>
                        <th>Coordinates</th>
                        <th>Radius (m)</th>
                        <th>Status</th>
                        <th class="text-center pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 text-muted">@item.CID</td>
                            <td>
                                <img src="@item.Logo"
                                     style="height:36px; border-radius:6px;"
                                     onerror="this.style.display='none'" />
                            </td>
                            <td class="fw-bold">@item.CompanyName</td>
                            <td class="text-muted small">
                                @item.Latitude, @item.Longitude
                            </td>
                            <td class="text-muted">@item.Radius</td>
                            <td>
                                @if (item.Status)
                                {
                                    <span class="badge bg-success-subtle
                                                 text-success border border-success">
                                        Active
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-subtle
                                                 text-danger border border-danger">
                                        Inactive
                                    </span>
                                }
                            </td>
                            <td class="text-center pe-4">
                                <a asp-action="Manage" asp-route-id="@item.CID"
                                   class="btn btn-sm btn-light border text-primary me-1">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <form asp-action="Delete" method="post"
                                      class="d-inline"
                                      onsubmit="return confirm('Delete @item.CompanyName?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.CID" />
                                    <button type="submit"
                                            class="btn btn-sm btn-light border text-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>