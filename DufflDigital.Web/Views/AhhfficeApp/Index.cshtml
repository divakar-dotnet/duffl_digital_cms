@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Duffl | Ahhffice App</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body { background-color: #f8f9fa; }

        .sidebar {
            min-height: 100vh;
            width: 250px;
            background-color: #212529;
            color: white;
            position: fixed;
            z-index: 100;
        }

        .main-content { margin-left: 250px; padding: 20px; }

        .nav-link { color: rgba(255,255,255,0.7); transition: 0.3s; }
        .nav-link:hover { color: #FFB300; }
        .nav-link.active { color: #FFB300; font-weight: bold; }

        .module-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            border-radius: 15px;
            cursor: pointer;
        }

        .module-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.12) !important;
        }

        .module-card .card-body { padding: 40px 30px; }

        .module-icon {
            font-size: 48px;
            margin-bottom: 16px;
        }
    </style>
</head>
<body>

    <!-- Sidebar -->
    <div class="sidebar d-flex flex-column p-3">
        <h3 class="text-center mb-4">Duffl <span class="fw-light">Admin</span></h3>
        <ul class="nav nav-pills flex-column mb-auto">
            <li class="nav-item">
                <a asp-controller="Dashboard" asp-action="Index" class="nav-link">
                    <i class="bi bi-speedometer2 me-2"></i> Dashboard
                </a>
            </li>
            <li>
                <a asp-controller="AhhfficeApp" asp-action="Index"
                   class="nav-link active">
                    <i class="bi bi-buildings me-2"></i> Ahhffice App
                </a>
            </li>
            <li>
                <a href="#" class="nav-link">
                    <i class="bi bi-gear me-2"></i> Settings
                </a>
            </li>
        </ul>
        <hr>
        <a asp-controller="Account" asp-action="Logout"
           class="btn btn-outline-danger btn-sm w-100">
            <i class="bi bi-box-arrow-right me-2"></i> Logout
        </a>
    </div>

    <!-- Main Content -->
    <div class="main-content">

        <!-- Top Bar -->
        <nav class="navbar navbar-expand-lg mb-4 rounded px-3 bg-white shadow-sm">
            <div class="container-fluid">
                <span class="navbar-brand mb-0 h5 text-secondary fw-bold">
                    <i class="bi bi-buildings me-2 text-warning"></i>
                    Ahhffice App
                </span>
                <a asp-controller="Dashboard" asp-action="Index"
                   class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
                </a>
            </div>
        </nav>

        <div class="container-fluid">
            <p class="text-muted mb-4">Select a section to manage:</p>

            <div class="row g-4">

                <!-- Company Button -->
                <div class="col-md-4">
                    <a asp-controller="AhhfficeApp" asp-action="Companies"
                       class="text-decoration-none">
                        <div class="card module-card shadow-sm border-0 text-center">
                            <div class="card-body">
                                <div class="module-icon text-warning">
                                    <i class="bi bi-buildings"></i>
                                </div>
                                <h4 class="fw-bold text-dark">Company</h4>
                                <p class="text-muted small mb-0">
                                    Manage company details, geolocation,
                                    logos and active status.
                                </p>
                            </div>
                        </div>
                    </a>
                </div>

               <!-- Users Button — now active -->
<div class="col-md-4">
    <a asp-controller="AhhfficeApp" asp-action="Users"
       class="text-decoration-none">
        <div class="card module-card shadow-sm border-0 text-center">
            <div class="card-body" style="padding:40px 30px;">
                <div class="module-icon text-warning" style="font-size:48px;margin-bottom:16px;">
                    <i class="bi bi-people"></i>
                </div>
                <h4 class="fw-bold text-dark">Users</h4>
                <p class="text-muted small mb-0">
                    Manage admin users and their access
                    permissions per company.
                </p>
            </div>
        </div>
    </a>
</div>

            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>