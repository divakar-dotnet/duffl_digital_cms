@model IEnumerable<DufflDigital.Web.Models.AhhfficeUser>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Duffl | User Management</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.5/css/jquery.dataTables.min.css">
    <style>
        body { background-color: #f8f9fa; }
        .sidebar {
            min-height: 100vh; width: 250px;
            background-color: #212529; color: white;
            position: fixed; z-index: 100;
        }
        .main-content { margin-left: 250px; padding: 20px; }
        .nav-link { color: rgba(255,255,255,0.7); transition: 0.3s; }
        .nav-link:hover, .nav-link.active { color: #FFB300; font-weight: bold; }

        #tblUsers thead th {
            background: #212529 !important;
            color: #fff !important;
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            padding: 14px 12px;
            border: none !important;
        }
        #tblUsers tbody td {
            font-size: 13px;
            padding: 11px 12px;
            vertical-align: middle;
            border-bottom: 1px solid #f0f0f0;
        }
        #tblUsers tbody tr:hover { background: #fffbf0; }
        .dataTables_filter { display: none !important; }
        .dataTables_info   { display: none !important; }
    </style>
</head>
<body>

    <!-- Sidebar -->
    <div class="sidebar d-flex flex-column p-3">
        <h3 class="text-center mb-4">Duffl <span class="fw-light">Admin</span></h3>
        <ul class="nav nav-pills flex-column mb-auto">
            <li><a asp-controller="Dashboard" asp-action="Index" class="nav-link">
                <i class="bi bi-speedometer2 me-2"></i> Dashboard</a></li>
            <li><a asp-controller="AhhfficeApp" asp-action="Index" class="nav-link active">
                <i class="bi bi-buildings me-2"></i> Ahhffice App</a></li>
            <li><a href="#" class="nav-link">
                <i class="bi bi-gear me-2"></i> Settings</a></li>
        </ul>
        <hr>
        <a asp-controller="Account" asp-action="Logout"
           class="btn btn-outline-danger btn-sm w-100">
            <i class="bi bi-box-arrow-right me-2"></i> Logout
        </a>
    </div>

    <!-- Main Content -->
    <div class="main-content">

        <nav class="navbar mb-4 rounded px-3 bg-white shadow-sm">
            <div class="container-fluid">
                <span class="navbar-brand mb-0 h5 text-secondary fw-bold">
                    <i class="bi bi-people me-2 text-warning"></i> User Management
                </span>
                <div class="d-flex gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-arrow-left me-1"></i> Back
                    </a>
                    <a asp-action="ManageUser" class="btn btn-warning text-white fw-bold btn-sm px-3">
                        <i class="bi bi-plus-lg me-1"></i> Add User
                    </a>
                </div>
            </div>
        </nav>

        @if (TempData["SuccessMsg"] != null)
        {
            <div class="alert alert-success py-2 px-3 mb-3" style="font-size:13px;">
                @TempData["SuccessMsg"]
            </div>
        }
        @if (TempData["ErrorMsg"] != null)
        {
            <div class="alert alert-danger py-2 px-3 mb-3" style="font-size:13px;">
                @TempData["ErrorMsg"]
            </div>
        }

        <p class="fw-bold text-dark mb-2" style="font-size:14px;">
            Total Users: <span class="text-warning">@Model.Count()</span>
        </p>

        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            @if (Model.Any())
            {
                <table id="tblUsers" class="table align-middle mb-0 w-100">
                    <thead>
                        <tr>
                            <th class="ps-4">S.No</th>
                            <th>Emp ID</th>
                            <th>Name</th>
                            <th>Company</th>
                            <th>Role</th>
                            <th>Username</th>
                            <th>Email</th>
                            <th>Mobile</th>
                            <th>Status</th>
                            <th class="text-center pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{int sno = 1;}
                        @foreach (var u in Model)
                        {
                            <tr>
                                <td class="ps-4 text-muted">@sno</td>
                                <td class="fw-bold">@u.EmpLoginID</td>
                                <td>@u.FullName</td>
                                <td class="text-muted small">@u.CompanyName</td>
                                <td>
                                    <span class="badge bg-dark">@u.Role</span>
                                </td>
                                <td>@u.Username</td>
                                <td class="text-muted small">@u.EmailID</td>
                                <td class="text-muted small">@u.MobileNo</td>
                                <td>
                                    @if (u.Status)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger">Inactive</span>
                                    }
                                </td>
                                <td class="text-center pe-4" style="white-space:nowrap;">
                                    <a asp-action="ManageUser" asp-route-id="@u.UID"
                                       class="btn btn-sm btn-light border text-primary me-1">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <form asp-action="DeleteUser" method="post" class="d-inline"
                                          onsubmit="return confirm('Delete user @u.Username?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@u.UID" />
                                        <button type="submit" class="btn btn-sm btn-light border text-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                            sno++;
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="text-center py-5">
                    <h5 class="text-muted">No Users Found</h5>
                </div>
            }
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.min.js"></script>
    <script>
        $(document).ready(function () {
            var table = $('#tblUsers').DataTable({
                pageLength: 25, bSort: false, paging: true
            });
            var rowCount = table.rows().count();
            if (rowCount <= 25) {
                table.page.len(rowCount).draw();
                $('.dataTables_paginate').hide();
            }
        });
    </script>
</body>
</html>