@model DufflDigital.Web.Models.Company
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Duffl | @(Model.CID == 0 ? "Add Company" : "Edit Company")</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body { background-color: #f8f9fa; }

        .sidebar {
            min-height: 100vh;
            width: 250px;
            background-color: #212529;
            color: white;
            position: fixed;
            z-index: 100;
        }

        .main-content { margin-left: 250px; padding: 20px; }

        .nav-link { color: rgba(255,255,255,0.7); transition: 0.3s; }
        .nav-link:hover { color: #FFB300; }
        .nav-link.active { color: #FFB300; font-weight: bold; }

        .form-control:focus {
            border-color: #FFB300;
            box-shadow: 0 0 0 0.15rem rgba(255,179,0,0.25);
        }
    </style>
</head>
<body>

    <!-- Sidebar -->
    <div class="sidebar d-flex flex-column p-3">
        <h3 class="text-center mb-4">Duffl <span class="fw-light">Admin</span></h3>
        <ul class="nav nav-pills flex-column mb-auto">
            <li class="nav-item">
                <a asp-controller="Dashboard" asp-action="Index" class="nav-link">
                    <i class="bi bi-speedometer2 me-2"></i> Dashboard
                </a>
            </li>
            <li>
                <a asp-controller="AhhfficeApp" asp-action="Index"
                   class="nav-link active">
                    <i class="bi bi-buildings me-2"></i> Ahhffice App
                </a>
            </li>
            <li>
                <a href="#" class="nav-link">
                    <i class="bi bi-gear me-2"></i> Settings
                </a>
            </li>
        </ul>
        <hr>
        <a asp-controller="Account" asp-action="Logout"
           class="btn btn-outline-danger btn-sm w-100">
            <i class="bi bi-box-arrow-right me-2"></i> Logout
        </a>
    </div>

    <!-- Main Content -->
    <div class="main-content">

        <!-- Top Bar -->
        <nav class="navbar navbar-expand-lg mb-4 rounded px-3 bg-white shadow-sm">
            <div class="container-fluid">
                <span class="navbar-brand mb-0 h5 text-secondary fw-bold">
                    <i class="bi bi-buildings me-2 text-warning"></i>
                    @(Model.CID == 0 ? "Add New Company" : "Edit Company")
                </span>
                <a asp-action="Companies"
                   class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-arrow-left me-1"></i> Back to Companies
                </a>
            </div>
        </nav>

        <!-- Form Card -->
        <div class="card border-0 shadow-sm rounded-4 mx-auto"
             style="max-width: 700px;">
            <div class="card-body p-5">
                <form asp-action="Save" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="CID" />

                    <div class="mb-3">
                        <label class="form-label fw-bold small">
                            Company Name <span class="text-danger">*</span>
                        </label>
                        <input asp-for="CompanyName" class="form-control" required />
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small">Latitude</label>
                            <input asp-for="Latitude" class="form-control"
                                   placeholder="13.045..." />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small">Longitude</label>
                            <input asp-for="Longitude" class="form-control"
                                   placeholder="80.243..." />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small">
                                Punch Radius (Meters)
                            </label>
                            <input asp-for="Radius" class="form-control"
                                   placeholder="100" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small">Logo URL</label>
                            <input asp-for="Logo" class="form-control"
                                   placeholder="https://..." />
                        </div>
                    </div>

                    <div class="form-check form-switch mb-4">
                        <input class="form-check-input" type="checkbox"
                               asp-for="Status" id="statusSwitch" />
                        <label class="form-check-label fw-bold small"
                               for="statusSwitch">
                            Active Status
                        </label>
                    </div>

                    <div class="pt-3 border-top d-flex gap-2">
                        <button type="submit"
                                class="btn btn-warning text-white fw-bold px-4">
                            <i class="bi bi-check-lg me-1"></i>
                            @(Model.CID == 0 ? "SAVE COMPANY" : "UPDATE COMPANY")
                        </button>
                        <a asp-action="Companies" class="btn btn-light border px-4">
                            CANCEL
                        </a>
                    </div>
                </form>
            </div>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>