@{ Layout = null; }
<!DOCTYPE html>
<html>
<head>
    <title>Duffl Admin | Login</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body { background: linear-gradient(180deg, #FFFFFF 0%, #FFB300 100%); height: 100vh; display: flex; align-items: center; justify-content: center; margin: 0; }
        .login-card { background: white; padding: 50px; border-radius: 15px; box-shadow: 0 15px 35px rgba(0,0,0,0.1); width: 100%; max-width: 420px; }
        .logo { font-size: 32px; font-weight: bold; font-family: 'Segoe UI', sans-serif; text-align:center; }
        .logo span { font-weight: 300; }
        .btn-go { border: 2px solid #FFB300; color: #FFB300; font-weight: bold; border-radius: 5px; width: 120px; transition: 0.3s; background: transparent; }
        .btn-go:hover { background: #FFB300; color: white; }
        .form-control { border: none; border-bottom: 1px solid #ced4da; border-radius: 0; padding: 10px 0; margin-bottom: 20px; }
        .form-control:focus { box-shadow: none; border-bottom: 2px solid #FFB300; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="logo mb-2">Duffl <span>Digital</span></div>
        <h5 class="text-warning text-center mb-5" style="letter-spacing: 4px; font-weight: bold;">LOGIN</h5>

        <form asp-action="Login" asp-controller="Account" method="post">
            <input type="text" name="email" class="form-control" placeholder="Username" required autocomplete="off">
            <input type="password" name="password" class="form-control" placeholder="Password" required>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger py-2 small">@ViewBag.Error</div>
            }

            <div class="text-center">
                <button type="submit" class="btn btn-go mt-3">GO</button>
            </div>
        </form>

        <div class="mt-4 text-center">
            <a asp-action="ForgotPassword" asp-controller="Account" class="text-muted small text-decoration-none">Forgot your password?</a>
        </div>
    </div>
</body>
</html>